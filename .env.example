GEMINI_API_KEY=your_gemini_api_key_here

# Paddle Billing Configuration
PADDLE_ENVIRONMENT=sandbox
PADDLE_CLIENT_TOKEN=your_paddle_client_token
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret
PADDLE_STARTER_PLAN_PRICE_ID=your_starter_price_id
PADDLE_PRO_PLAN_PRICE_ID=your_pro_price_id
PADDLE_PREMIUM_PLAN_PRICE_ID=your_premium_price_id
# Server-side API key (Paddle Dashboard > Developer Tools > Authentication).
# Needed for in-app "Cancel subscription" / "Switch plan" actions to call the
# Paddle API directly. Without it, those actions fall back to a manual
# support request instead of a broken/duplicate-checkout flow.
PADDLE_API_KEY=your_paddle_api_key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id

# Mailtrap Email Sending API
MAILTRAP_API_TOKEN=your_mailtrap_api_token
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME=Your App Name

# Database (PostgreSQL - Railway/Supabase)
DATABASE_URL=postgresql://user:password@host:5432/dbname
